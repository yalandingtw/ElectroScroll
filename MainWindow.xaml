<Window x:Class="ElectroScroll.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ElectroScroll"
        Width="980"
        Height="700"
        MinWidth="840"
        MinHeight="620"
        Background="#F5F7F4">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#1F2626" />
        <SolidColorBrush x:Key="MutedBrush" Color="#66706F" />
        <SolidColorBrush x:Key="LineBrush" Color="#DDE2DF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F8B8D" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#09686A" />
        <SolidColorBrush x:Key="WarmBrush" Color="#E4572E" />

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TuneLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TuneValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ElectroScroll"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="26"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding Text[AppSubtitle]}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           VerticalAlignment="Center">
                    <CheckBox Content="{Binding Text[Enabled]}"
                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Margin="0,0,18,0" />
                    <CheckBox Content="{Binding Text[Modifiers]}"
                              IsChecked="{Binding BypassWithModifiers, Mode=TwoWay}"
                              Margin="0,0,12,0" />
                    <CheckBox Content="{Binding Text[Fullscreen]}"
                              IsChecked="{Binding AutoBypassFullscreen, Mode=TwoWay}"
                              Margin="0,0,12,0" />
                    <CheckBox Content="{Binding Text[Games]}"
                              IsChecked="{Binding AutoBypassKnownGames, Mode=TwoWay}"
                              Margin="0,0,12,0" />
                    <CheckBox Content="{Binding Text[Log]}"
                              IsChecked="{Binding DiagnosticsLoggingEnabled, Mode=TwoWay}"
                              Margin="0,0,12,0" />
                    <TextBlock Text="{Binding Text[Language]}"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <Button Content="EN"
                            Command="{Binding UseEnglishCommand}"
                            MinWidth="42"
                            Margin="0,0,6,0" />
                    <Button Content="繁中"
                            Command="{Binding UseTraditionalChineseCommand}"
                            MinWidth="50" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0"
                    Grid.Row="0"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,16,16">
                <StackPanel>
                    <TextBlock Text="{Binding Text[Presets]}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource InkBrush}" />
                    <UniformGrid Columns="3"
                                 Margin="0,14,0,0">
                        <Button Content="{Binding Text[Precise]}"
                                Command="{Binding ApplyPreciseCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="{Binding Text[Balanced]}"
                                Command="{Binding ApplyBalancedCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="{Binding Text[FreeSpin]}"
                                Command="{Binding ApplyFreeSpinCommand}" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="0"
                    Grid.Row="1"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,16,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding Text[Physics]}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}"
                                   Margin="0,0,0,8" />

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[Step]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding Step, StringFormat={}{0:0.00}x}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="0.3" Maximum="1.8" Value="{Binding Step, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[StepHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[Threshold]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding Threshold, StringFormat={}{0:0.000}}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="0.01" Maximum="0.12" Value="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[ThresholdHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[Acceleration]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding Acceleration, StringFormat={}{0:0.0}x}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="2" Maximum="36" Value="{Binding Acceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[AccelerationHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[MaxBoost]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding MaxBoost, StringFormat={}{0:0.0}x}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="1.2" Maximum="9" Value="{Binding MaxBoost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[MaxBoostHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[ImpulseTime]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding KickMs, StringFormat={}{0:0} ms}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="55" Maximum="190" Value="{Binding KickMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[ImpulseTimeHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[Friction]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding FrictionMs, StringFormat={}{0:0} ms}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="80" Maximum="900" Value="{Binding FrictionMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[FrictionHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[Flywheel]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding Flywheel, StringFormat={}{0:0.00}}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="0" Maximum="1.5" Value="{Binding Flywheel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[FlywheelHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[DirectShare]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding DirectShare, StringFormat={}{0:0}%}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="0" Maximum="80" Value="{Binding DirectShare, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[DirectShareHelp]}" Style="{StaticResource HelpText}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Text[Smoothness]}" Style="{StaticResource TuneLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding Smoothness, StringFormat={}{0} steps}" Style="{StaticResource TuneValue}" />
                        </Grid>
                        <Slider Minimum="1" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Smoothness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{Binding Text[SmoothnessHelp]}" Style="{StaticResource HelpText}" />

                        <UniformGrid Columns="2"
                                     Margin="0,18,0,0">
                            <Button Content="{Binding Text[ResetMotion]}"
                                    Command="{Binding ResetMotionCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="{Binding Text[Save]}"
                                    Command="{Binding SaveCommand}"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    BorderBrush="{StaticResource AccentDarkBrush}" />
                        </UniformGrid>

                        <TextBlock Text="{Binding SaveStatus}"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1"
                  Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0"
                             Columns="4"
                             Margin="0,0,0,16">
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{Binding Text[Speed]}" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding Speed}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{Binding Text[Boost]}" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding Boost}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{Binding Text[Velocity]}" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding Velocity}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="{Binding Text[Mode]}" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding Status}" Style="{StaticResource MetricValue}" FontSize="18" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorder}"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Text[Charts]}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{Binding Text[ChartsHelp]}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>

                            <CheckBox Grid.Column="1"
                                      Content="{Binding Text[ShowCharts]}"
                                      IsChecked="{Binding ChartsEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="1"
                              Visibility="{Binding ChartVisibility}"
                              Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="150" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Text[InputSignal]}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding InputSignal}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontFamily="Consolas"
                                           Margin="6,0,14,0" />
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="{StaticResource WarmBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Text[OutputSignal]}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding OutputSignal}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontFamily="Consolas"
                                           Margin="6,0,0,0" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Background="#F8FAF8"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    ClipToBounds="True">
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="560"
                                            Height="140"
                                            ClipToBounds="True">
                                        <Rectangle Width="560"
                                                   Height="140"
                                                   Fill="#F8FAF8" />
                                        <Line X1="0" X2="560" Y1="35" Y2="35" Stroke="#E5EAE7" StrokeThickness="1" />
                                        <Line X1="0" X2="560" Y1="70" Y2="70" Stroke="#E5EAE7" StrokeThickness="1" />
                                        <Line X1="0" X2="560" Y1="105" Y2="105" Stroke="#E5EAE7" StrokeThickness="1" />
                                        <Polyline Points="{Binding OutputChartPoints}"
                                                  Stroke="{StaticResource WarmBrush}"
                                                  StrokeThickness="2.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                        <Polyline Points="{Binding InputChartPoints}"
                                                  Stroke="{StaticResource AccentBrush}"
                                                  StrokeThickness="2.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Text[Target]}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkBrush}" />

                        <Grid Grid.Row="1"
                              Margin="0,14,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Text[Profile]}" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding ProfileName}" FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1" Text="{Binding Text[Process]}" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProcessName}" FontWeight="SemiBold" Margin="0,8,0,0" />

                            <TextBlock Grid.Row="2" Text="{Binding Text[Window]}" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WindowTitle}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="3" Text="{Binding Text[Diagnostics]}" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Diagnostics}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Margin="0,8,0,0" />
                        </Grid>

                        <Border Grid.Row="2"
                                Background="#F1F4F2"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="{Binding Text[ImplementationNotes]}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="21"
                                           Text="{Binding Text[ImplementationNote1]}" />
                                <TextBlock Margin="0,14,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="21"
                                           Text="{Binding PerformanceStatus}" />
                                <TextBlock Margin="0,14,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="21"
                                           Text="{Binding Text[CompatibilityNote]}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
